    <style>
        /* カラーパレット & 基本設定 */
        :root {
            --primary-color: #0077b6; /* 青空と湖のブルー */
            --secondary-color: #e9c46a; /* ゴビ砂漠のゴールド */
            --accent-color: #2a9d8f; /* 自然・草原のグリーン */
            --dark-color: #264653; /* テキスト用ネイビー */
            --light-color: #f8f9fa; /* 背景用グレー */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
        }

        body {
            background-color: var(--light-color);
            color: var(--dark-color);
            line-height: 1.8;
            letter-spacing: 0.05em;
        }

        /* ヘッダー & ナビゲーション */
        header {
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('hero-mongolia-ai.jpg') no-repeat center center/cover;
            /* AI PROMPT: Hyper-realistic cinematic shot of Mongolian endless steppe, blue sky with white clouds, majestic mountains in background, high quality --ar 16:9 */
            height: 85vh;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            text-align: center;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .logo {
            font-size: 26px;
            font-weight: bold;
            letter-spacing: 2px;
            color: var(--secondary-color);
        }

        .nav-links {
            display: flex;
            list-style: none;
        }

        .nav-links li {
            margin-left: 30px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            transition: 0.3s;
        }

        .nav-links a:hover {
            color: var(--secondary-color);
        }

        .hero-text {
            margin-bottom: 20vh;
        }

        .hero-text h1 {
            font-size: 52px;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.6);
            font-weight: 700;
        }

        .hero-text p {
            font-size: 22px;
            color: #f0f0f0;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.6);
        }

        /* セクション共通スタイル */
        section {
            padding: 90px 10%;
        }

        .section-title {
            text-align: center;
            font-size: 32px;
            margin-bottom: 60px;
            position: relative;
            color: var(--dark-color);
            font-weight: 700;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background-color: var(--primary-color);
            margin: 15px auto 0;
            border-radius: 2px;
        }

        .section-subtitle {
            display: block;
            font-size: 14px;
            color: var(--primary-color);
            text-align: center;
            margin-top: -50px;
            margin-bottom: 50px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* モンゴル大自然ギャラリー */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .gallery-item {
            position: relative;
            overflow: hidden;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            height: 280px;
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.6s ease;
        }

        .gallery-item:hover img {
            transform: scale(1.08);
        }

        .gallery-desc {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background: linear-gradient(transparent, rgba(0,0,0,0.85));
            color: white;
            padding: 25px 20px;
            font-size: 18px;
            font-weight: bold;
        }

        /* CEOプロフィールセクション */
        .ceo-container {
            background-color: white;
            display: flex;
            align-items: center;
            gap: 60px;
            padding: 50px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        }

        .ceo-img {
            flex: 1;
            max-width: 350px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

        .ceo-img img {
            width: 100%;
            height: auto;
            display: block;
        }

        .ceo-content {
            flex: 2;
        }

        .ceo-content h3 {
            font-size: 28px;
            color: var(--dark-color);
            margin-bottom: 5px;
        }

        .ceo-content .title {
            font-size: 14px;
            color: var(--primary-color);
            font-weight: 600;
            margin-bottom: 25px;
            display: block;
        }

        .ceo-content p {
            font-size: 15px;
            color: #4a5568;
            margin-bottom: 15px;
            text-align: justify;
        }

        /* チームメンバー (10名) */
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
        }

        .team-card {
            background-color: white;
            border-radius: 12px;
            overflow: hidden;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
            transition: 0.3s;
            padding-bottom: 20px;
        }

        .team-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.08);
        }

        .team-card img {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .team-card h4 {
            margin: 15px 0 5px;
            font-size: 16px;
            color: var(--dark-color);
        }

        .team-card p {
            color: var(--accent-color);
            font-size: 13px;
            font-weight: 600;
        }

        /* フッター */
        footer {
            background-color: var(--dark-color);
            color: rgba(255,255,255,0.8);
            text-align: center;
            padding: 40px;
            font-size: 14px;
        }
